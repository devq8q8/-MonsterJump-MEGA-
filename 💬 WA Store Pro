function cpCode(btn){
  const code=btn.parentElement.textContent.replace('نسخ','').trim();
  navigator.clipboard.writeText(code).then(()=>{btn.textContent='✅';setTimeout(()=>btn.textContent='نسخ',1500);}).catch(()=>toast('❌ فشل النسخ'));
}

function prevBroad(v){document.getElementById('bprev').textContent=v||'اكتب رسالتك للمعاينة...';}
function exportCSV(){
  if(!products.length){toast('⚠️ لا توجد منتجات');return;}
  const rows=['ID,الاسم,السعر,الكمية,الوصف',...products.map(p=>`${p.id},"${p.name}",${p.price},${p.stock},"${p.desc||''}"`)];
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob(['\ufeff'+rows.join('\n')],{type:'text/csv;charset=utf-8'}));
  a.download='products.csv';a.click();
  toast('📥 تم تصدير المنتجات');
}
function saveBot(){
  document.getElementById('cbn').textContent=document.getElementById('bname').value||'بوت متجري';
  toast('✅ تم حفظ إعدادات البوت');
}

function toast(msg){
  const t=document.createElement('div');
  t.className='toast';t.textContent=msg;
  document.getElementById('tbox').appendChild(t);
  setTimeout(()=>t.remove(),3100);
}
