<script>
let products=[], cart={}, msgCount=0, searchQ='', customRules=[];

function go(id,el){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('p-'+id).classList.add('active');
  if(el)el.classList.add('active');
}
function tog(el){el.classList.toggle('on')}

function addProduct(){
  const name=document.getElementById('pn').value.trim();
  const price=parseFloat(document.getElementById('pp').value);
  const emoji=document.getElementById('pe').value.trim()||'📦';
  const stock=parseInt(document.getElementById('ps').value)||10;
  const desc=document.getElementById('pd').value.trim();
  if(!name||isNaN(price)||price<0){toast('⚠️ أدخل الاسم والسعر');return;}
  const id=100+products.length+1;
  products.push({id,name,price,emoji,stock,desc});
  renderP();clearF();
  toast(`✅ تمت إضافة "${name}"`);
}
function delProduct(id){
  const p=products.find(x=>x.id===id);
  products=products.filter(x=>x.id!==id);
  renderP();
  toast(`🗑️ حُذف "${p?.name}"`);
}
function clearF(){['pn','pp','pe','ps','pd'].forEach(i=>document.getElementById(i).value='')}
function filterP(v){searchQ=v.toLowerCase();renderP()}
function renderP(){
  const f=products.filter(p=>p.name.toLowerCase().includes(searchQ)||String(p.id).includes(searchQ));
  document.getElementById('s-p').textContent=products.length;
  document.getElementById('pclbl').textContent=f.length+' منتج';
  const tb=document.getElementById('ptb');
  if(!f.length){tb.innerHTML=`<tr><td colspan="5"><div class="empty-s"><div class="ei">📦</div><p>${products.length?'لا نتائج':'أضف أول منتج!'}</p></div></td></tr>`;return;}
  tb.innerHTML=f.map(p=>`<tr>
    <td><div class="pcel"><div class="pemo">${p.emoji}</div><div><div class="pnm">${p.name}</div><div class="pid">ID: ${p.id}</div></div></div></td>
    <td><span class="ptag">${p.price.toFixed(3)} د.ك</span></td>
    <td><span style="color:${p.stock>5?'var(--g)':'var(--gold)'};font-size:.8rem;font-weight:600">${p.stock>5?'✅':'⚠️'} ${p.stock}</span></td>
    <td style="font-family:monospace;color:var(--tx3)">${p.id}</td>
    <td><div class="act-col"><button class="btn btn-xs btn-g" onclick="qcmd('${p.id}');go('chat',document.querySelectorAll('.tab')[3])">💬</button><button class="btn btn-xs btn-d" onclick="delProduct(${p.id})">🗑️</button></div></td>
  </tr>`).join('');
}

function sendMsg(){
  const inp=document.getElementById('ci');
  const txt=inp.value.trim();
  if(!txt)return;
  inp.value='';
  appendMsg(txt,'s');
  msgCount++;
  document.getElementById('s-m').textContent=msgCount;
  const typing=appendMsg('يكتب...','r',true);
  callBot(txt).then(reply=>{typing.remove();appendMsg(reply,'r');});
}
function qcmd(cmd){
  const tab=document.getElementById('p-chat');
  if(!tab.classList.contains('active'))go('chat',document.querySelectorAll('.tab')[3]);
  document.getElementById('ci').value=cmd;
  sendMsg();
}
function appendMsg(text,side,typing=false){
  const box=document.getElementById('cms');
  const d=document.createElement('div');
  d.className=`msg ${side}`;
  d.innerHTML=`<div class="bbl">${typing?'<i style="opacity:.4">يكتب...</i>':text.replace(/\n/g,'<br>').replace(/\*(.*?)\*/g,'<b>$1</b>')}</div>${typing?'':'<span class="mt">الآن</span>'}`;
  box.appendChild(d);
  box.scrollTop=box.scrollHeight;
  return d;
}

async function callBot(msg){
  const direct=handleDirect(msg);
  if(direct)return direct;
  const apiKey=document.getElementById('apikey')?.value?.trim();
  if(!apiKey)return getFallback(msg);
  try{
    const sys=buildSys();
    const res=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01'},
      body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:500,system:sys,messages:[{role:'user',content:msg}]})
    });
    if(!res.ok)throw new Error('err');
    const data=await res.json();
    return data.content?.[0]?.text||getFallback(msg);
  }catch(e){return getFallback(msg);}
}

function buildSys(){
  const name=document.getElementById('bname')?.value||'بوت المتجر';
  const pl=products.length?products.map(p=>`[${p.id}] ${p.name} | ${p.price.toFixed(3)}د.ك | ${p.desc||''}`).join('\n'):'لا منتجات';
  return `أنت ${name} — بوت متجر واتساب ذكي.
المنتجات:\n${pl}

قواعد:
- أجب بالعربية الخليجية فقط
- كن قصيراً وودياً (أقل من 5 أسطر)
- للطلب: قل أرسل "طلب [رقم]"
- لإتمام الطلب: اطلب الاسم والعنوان وطريقة الدفع
- طرق الدفع: عند الاستلام، زين كاش، STC Pay`;
}

function handleDirect(msg){
  const m=msg.trim().toLowerCase();
  const name=document.getElementById('bname')?.value||'بوت المتجر';
  if(m==='عرض'||m==='منتجات'||m==='عرض المنتجات'){
    if(!products.length)return'📦 لا توجد منتجات حالياً.';
    return'📋 *قائمة المنتجات:*\n\n'+products.map(p=>`${p.emoji} [${p.id}] ${p.name}\n   💰 ${p.price.toFixed(3)} د.ك`).join('\n\n')+'\n\n_أرسل رقم المنتج للتفاصيل_';
  }
  if(m==='سلة'){
    const keys=Object.keys(cart);
    if(!keys.length)return'🛒 سلتك فارغة!\nأرسل "طلب [رقم]" لإضافة منتج.';
    let total=0;
    const lines=keys.map(k=>{const p=products.find(x=>x.id==k);if(!p)return null;total+=p.price*cart[k];return`${p.emoji} ${p.name} ×${cart[k]} = ${(p.price*cart[k]).toFixed(3)} د.ك`;}).filter(Boolean);
    return`🛒 *سلتك:*\n\n${lines.join('\n')}\n\n💰 *الإجمالي: ${total.toFixed(3)} د.ك*\n\nأرسل *إتمام الطلب* للمتابعة.`;
  }
  if(m==='إتمام الطلب'||m==='اتمام الطلب'){
    const keys=Object.keys(cart);
    if(!keys.length)return'🛒 سلتك فارغة!';
    let total=0;
    Object.keys(cart).forEach(k=>{const p=products.find(x=>x.id==k);if(p)total+=p.price*cart[k];});
    cart={};
    return`✅ *تم تسجيل طلبك!*\n\n💰 الإجمالي: ${total.toFixed(3)} د.ك\n\nاختر طريقة الدفع:\n1️⃣ الدفع عند الاستلام\n2️⃣ زين كاش\n3️⃣ STC Pay`;
  }
  if(m==='مساعدة'||m==='help'){
    return`🤖 *أوامر ${name}:*\n\n📋 *عرض* — قائمة المنتجات\n🔢 *[رقم]* — تفاصيل منتج\n🛒 *طلب [رقم]* — أضف للسلة\n🧺 *سلة* — عرض السلة\n✅ *إتمام الطلب* — تأكيد الطلب`;
  }
  const om=m.match(/^طلب\s+(\d+)/);
  if(om){
    const id=parseInt(om[1]);
    const p=products.find(x=>x.id===id);
    if(!p)return`❌ المنتج رقم ${id} غير موجود.`;
    cart[id]=(cart[id]||0)+1;
    return`✅ أُضيف للسلة:\n${p.emoji} ${p.name} ×${cart[id]}\n💰 ${(p.price*cart[id]).toFixed(3)} د.ك\n\nأرسل *سلة* أو *إتمام الطلب*.`;
  }
  if(/^\d+$/.test(m)){
    const id=parseInt(m);
    const p=products.find(x=>x.id===id);
    if(!p)return`❌ لا يوجد منتج رقم ${id}.`;
    return`${p.emoji} *${p.name}*\n\n💰 السعر: ${p.price.toFixed(3)} د.ك\n📦 الكمية: ${p.stock}${p.desc?'\n📝 '+p.desc:''}\n\nللطلب أرسل: *طلب ${p.id}*`;
  }
  const rule=customRules.find(r=>msg.toLowerCase().includes(r.trigger.toLowerCase()));
  if(rule)return rule.response;
  return null;
}

function getFallback(msg){
  const m=msg.toLowerCase();
  if(m.includes('سعر')||m.includes('كم'))return products.length?'💰 أسعارنا:\n'+products.slice(0,3).map(p=>`${p.emoji} ${p.name}: ${p.price.toFixed(3)} د.ك`).join('\n')+'\n\nأرسل *عرض* للقائمة الكاملة.':'📦 لا توجد منتجات حالياً.';
  if(m.includes('مرحبا')||m.includes('اهلا')||m.includes('هلا'))return'👋 أهلاً وسهلاً!\nأرسل *عرض* لرؤية منتجاتنا.';
  if(m.includes('شكر'))return'😊 العفو! يسعدنا خدمتك.';
  return'🤖 أرسل *مساعدة* لقائمة الأوامر.';
}

function showRuleForm(){document.getElementById('rnrow').style.display='flex'}
function saveRule(){
  const trig=document.getElementById('rtrig').value.trim();
  const resp=document.getElementById('rresp').value.trim();
  if(!trig||!resp){toast('⚠️ أدخل الكلمة والرد');return;}
  customRules.push({trigger:trig,response:resp});
  const row=document.createElement('div');
  row.className='rule';
  row.innerHTML=`<span class="rtrig">${trig}</span><span class="rarr">→</span><span class="rresp">${resp}</span><div class="ract"><button class="btn btn-xs btn-d" onclick="this.closest('.rule').remove()">حذف</button></div>`;
  document.getElementById('rules-list').insertBefore(row,document.getElementById('rnrow'));
  document.getElementById('rnrow').style.display='none';
  document.getElementById('rtrig').value='';
  document.getElementById('rresp').value='';
  toast('✅ تمت إضافة القاعدة');
}

